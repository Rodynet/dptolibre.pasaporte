                                                <div className="text-right">
                                                    <p className="text-[10px] font-black text-slate-400 uppercase mb-2">Score Infoexperto</p>
                                                    <p className="text-4xl font-black text-emerald-600">890</p>
                                                </div>
                                            </div>
                                            <div className="bg-emerald-50 p-10 rounded-[2.5rem] border border-emerald-100 flex items-center justify-between">
                                                <div className="flex-1">
                                                    <h4 className="font-black text-emerald-900 text-xl mb-2 uppercase">Máquina de Ventas Activa</h4>
                                                    <p className="text-emerald-700 text-sm font-medium">Inquilino sin aval propietario. Ofrece Garantía Blindato para cerrar hoy mismo y sumar <strong>+$15.000 Markup</strong>.</p>
                                                </div>
                                                <button className="ml-8 bg-emerald-500 text-slate-900 font-black px-10 py-5 rounded-2xl text-xs uppercase tracking-widest shadow-xl">VENDER GARANTÍA</button>
                                            </div>
                                            <div className="flex gap-6">
                                                <button className="flex-1 bg-slate-900 text-white font-black py-5 rounded-2xl text-xs uppercase tracking-widest">DAR OK FINAL Y FIRMAR</button>
                                                <button className="bg-slate-100 text-slate-400 font-black px-10 py-5 rounded-2xl text-xs uppercase">RECHAZAR</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            )}
                        </div>
                    ) : (
                        <div className="mobile-frame">
                            <div className="notch"></div>
                            {profile === 'tenant' ? <TenantView /> : <OwnerView />}
                            
                            {/* Mobile Wizards */}
                            {activeWizard === 'wallet' && (
                                <WizardOverlay title="Mi Billetera" onClose={() => setActiveWizard(null)}>
                                    <div className="p-8 space-y-10">
                                        <div className="bg-slate-900 rounded-[2.5rem] p-10 text-white text-center relative overflow-hidden shadow-2xl">
                                            <ShieldCheck size={48} className="text-emerald-400 mx-auto mb-4" />
                                            <p className="text-xs font-black uppercase opacity-60">Fondo resguardado</p>
                                            <h2 className="text-4xl font-black mt-2">$410.860,22</h2>
                                            <div className="inline-flex items-center gap-1 bg-emerald-500/20 text-emerald-400 px-4 py-1.5 rounded-full text-[10px] font-black mt-6">
                                                <TrendingUp size={12} /> +$5.430 RENDIMIENTO HOY
                                            </div>
                                        </div>
                                        <div className="space-y-4">
                                            <button className="w-full bg-indigo-600 text-white font-black py-5 rounded-2xl text-xs uppercase tracking-widest flex items-center justify-center gap-3 shadow-xl">PAGAR ALQUILER <ArrowRight size={18}/></button>
                                            <button className="w-full bg-white border border-slate-200 text-slate-800 font-black py-5 rounded-2xl text-xs uppercase tracking-widest flex items-center justify-center gap-3">PAGAR SERVICIOS <Zap size={18}/></button>
                                            <button className="w-full text-slate-400 font-black py-3 text-[10px] uppercase">Retirar a mi Banco</button>
                                        </div>
                                    </div>
                                </WizardOverlay>
                            )}

                            {activeWizard === 'blinding' && (
                                <WizardOverlay title="Mago de Blindaje" onClose={() => setActiveWizard(null)}>
                                    <div className="p-8 space-y-8 flex flex-col justify-center h-full text-center">
                                        <div>
                                            <p className="text-indigo-600 font-black text-[10px] uppercase tracking-widest mb-4">¿Cuánto quieres resguardar?</p>
                                            <h2 className="text-5xl font-black text-slate-800">$450.000</h2>
                                            <p className="text-slate-400 text-xs mt-4">Equivale a tu próximo mes de alquiler</p>
                                        </div>
                                        <div className="bg-white p-6 rounded-[2rem] border-2 border-indigo-100 flex items-center justify-between text-left">
                                            <div className="flex items-center gap-4">
                                                <div className="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center"><Building size={24}/></div>
                                                <div>
                                                    <p className="text-[10px] font-black text-slate-400 uppercase">Desde mi banco</p>
                                                    <p className="text-sm font-bold text-slate-800 tracking-tight">Banco Galicia (*** 8901)</p>
                                                </div>
                                            </div>
                                            <ChevronRight className="text-indigo-600" />
                                        </div>
                                        <div className="bg-indigo-900 text-white p-6 rounded-[2rem] text-left relative overflow-hidden shadow-xl">
                                            <Sparkles className="absolute right-[-10px] top-[-10px] opacity-20" size={80}/>
                                            <h4 className="font-black text-xs uppercase mb-4 opacity-70">Beneficios Inmediatos</h4>
                                            <div className="space-y-3">
                                                <div className="flex items-center gap-2 text-xs font-bold"><CheckCircle2 size={16} className="text-emerald-400" /> +$5.400 Interés Mensual</div>
                                                <div className="flex items-center gap-2 text-xs font-bold"><CheckCircle2 size={16} className="text-emerald-400" /> +25 Puntos Score</div>
                                                <div className="flex items-center gap-2 text-xs font-bold"><CheckCircle2 size={16} className="text-emerald-400" /> +500 Millas Boutique</div>
                                            </div>
                                        </div>
                                        <button onClick={() => setActiveWizard(null)} className="bg-indigo-600 text-white font-black py-5 rounded-[2rem] text-sm uppercase tracking-widest shadow-2xl">BLINDAR AHORA</button>
                                    </div>
                                </WizardOverlay>
                            )}

                            {activeWizard === 'inventory' && (
                                <WizardOverlay title="Bitácora de Estado" onClose={() => setActiveWizard(null)}>
                                    <div className="p-6 space-y-6">
                                        <div className="bg-white p-4 rounded-3xl border border-slate-100 shadow-sm space-y-4">
                                            <div className="relative aspect-video rounded-2xl overflow-hidden bg-slate-200">
                                                <img src="https://images.unsplash.com/photo-1556911220-e15b29be8c8f?w=400" className="w-full h-full object-cover" />
                                                <div className="absolute top-3 left-3 bg-black/50 backdrop-blur px-3 py-1 rounded-full text-[8px] font-black text-white uppercase flex items-center gap-1">
                                                    <Clock size={10} /> 10/03/2026
                                                </div>
                                            </div>
                                            <div>
                                                <h4 className="font-black text-slate-800 text-sm">Cocina - Grifería</h4>
                                                <p className="text-[10px] text-slate-500 font-medium">Estado impecable. Sin goteos detectados por inquilino.</p>
                                            </div>
                                            <div className="flex items-center gap-2 text-emerald-600">
                                                <ShieldCheck size={14}/>
                                                <span className="text-[9px] font-black uppercase">Sello Inmutable Blindato</span>
                                            </div>
                                        </div>
                                        <div className="bg-white p-4 rounded-3xl border border-slate-100 shadow-sm opacity-50 grayscale">
                                            <div className="aspect-video rounded-2xl bg-slate-100 flex items-center justify-center text-slate-300">
                                                <PlusCircle size={32}/>
                                            </div>
                                            <p className="text-center text-[10px] font-black text-slate-400 mt-4 uppercase">Cargar Nuevo Punto</p>
                                        </div>
                                    </div>
                                </WizardOverlay>
                            )}
                        </div>
                    )}

                </div>
            );
        }

        // Inicialización de la App
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<BlindatoApp />);

        // Inicializar Lucide después del render
        window.onload = () => {
            lucide.createIcons();
        };
    </script>
</body>
</html>
