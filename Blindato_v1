                            <ShieldCheck size={100} className="absolute right-[-20px] bottom-[-20px] text-white/5" />
                            <div className="flex justify-between items-start mb-6">
                                <div>
                                    <p className="text-[10px] font-black uppercase text-indigo-400 tracking-widest">Saldo Galicia (Asociada)</p>
                                    <h3 className="text-2xl font-black">$185.200</h3>
                                </div>
                                <button className="bg-indigo-600 p-2 rounded-xl shadow-lg"><Plus size={16} /></button>
                            </div>
                            <div className="bg-white/10 p-3 rounded-2xl flex items-center justify-between border border-white/5 backdrop-blur-md">
                                <span className="text-[9px] font-black uppercase opacity-60">Alquiler Blindado</span>
                                <span className="text-xs font-black text-emerald-400">+$405.430,22</span>
                            </div>
                        </div>

                        {/* Cards Section */}
                        <div className="space-y-4">
                            <div className="bg-white p-5 rounded-3xl shadow-sm border border-slate-100 flex justify-between items-center">
                                <div>
                                    <span className="text-[9px] font-black bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full uppercase">Faltan 4 días</span>
                                    <h4 className="font-black text-slate-800 mt-2 text-sm">Caseros 1230, 4B</h4>
                                    <p className="text-xl font-black text-slate-600 mt-1">$450.000</p>
                                </div>
                                <button className="bg-slate-900 text-white text-[10px] font-black px-6 py-3 rounded-xl uppercase tracking-widest shadow-xl shadow-slate-200">PAGAR</button>
                            </div>

                            <div className="bg-indigo-600 p-6 rounded-[2.5rem] text-white shadow-xl relative overflow-hidden" onClick={() => setActiveWizard('blinding')}>
                                <Zap className="absolute right-[-10px] top-[-10px] text-white/10" size={80} />
                                <h4 className="text-[10px] font-black uppercase tracking-widest opacity-80 mb-4 tracking-widest">Misión: Blindar Mayo</h4>
                                <div className="flex justify-between text-[10px] font-black mb-2 uppercase">
                                    <span>Progreso de Resguardo</span>
                                    <span>45%</span>
                                </div>
                                <div className="h-2.5 bg-white/20 rounded-full overflow-hidden mb-4">
                                    <div className="h-full bg-emerald-400" style={{width: '45%'}}></div>
                                </div>
                                <button className="w-full bg-white text-indigo-600 font-black py-3 rounded-2xl text-[10px] uppercase tracking-widest">+ Ingresar Fondos</button>
                            </div>

                            {/* Bitácora / Property Log */}
                            <div className="bg-white p-5 rounded-3xl border border-slate-100 flex items-center gap-4 cursor-pointer" onClick={() => setActiveWizard('inventory')}>
                                <div className="w-12 h-12 bg-slate-50 text-slate-400 rounded-xl flex items-center justify-center">
                                    <Camera size={24}/>
                                </div>
                                <div>
                                    <h4 className="text-xs font-black text-slate-800 uppercase">Bitácora de Estado</h4>
                                    <p className="text-[9px] text-indigo-500 font-black uppercase">Última actualización: 10 Mar</p>
                                </div>
                                <ChevronRight className="ml-auto text-slate-200" />
                            </div>
                        </div>
                    </main>

                    {/* Bottom Nav */}
                    <nav className="absolute bottom-0 w-full bg-white px-6 py-5 flex justify-around items-center border-t border-slate-100 shadow-[0_-10px_20px_rgba(0,0,0,0.02)]">
                        <Home size={22} className="text-indigo-600" />
                        <FileText size={22} className="text-slate-300" />
                        <Wallet size={22} className="text-slate-300" />
                        <Gift size={22} className="text-slate-300" />
                    </nav>
                </div>
            );

            // Perfil Propietario (App Mobile)
            const OwnerView = () => (
                <div className="flex flex-col h-full animate-in slide-in-from-left duration-500">
                    <header className="bg-slate-900 px-6 pt-12 pb-8 rounded-b-[3rem] shadow-xl text-white">
                        <div className="flex justify-between items-center mb-8">
                            <div className="flex items-center gap-3">
                                <div className="w-10 h-10 rounded-full border-2 border-emerald-500 overflow-hidden bg-slate-700">
                                    <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Roberto" alt="Owner" />
                                </div>
                                <div className="flex flex-col">
                                    <span className="text-xs font-black leading-none">Roberto Daer</span>
