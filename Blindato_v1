<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blindato - Ecosistema Integral</title>
    <!-- Tailwind CSS para Estilos -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons (React Version) -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- React & ReactDOM -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <!-- Babel para JSX en el navegador -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .mobile-frame {
            width: 375px;
            height: 812px;
            border: 12px solid #0f172a;
            border-radius: 40px;
            overflow: hidden;
            position: relative;
            background: #f1f5f9;
            box-shadow: 0 50px 100px -20px rgba(0,0,0,0.25);
        }
        .notch {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 150px;
            height: 25px;
            background: #0f172a;
            border-bottom-left-radius: 15px;
            border-bottom-right-radius: 15px;
            z-index: 100;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;
        const { 
            ShieldCheck, TrendingUp, Award, Building2, Building, Users, FileText, Wallet, Gift, 
            Bell, Plus, Search, LayoutDashboard, Settings, CheckCircle2, Clock, AlertCircle, 
            X, ChevronRight, ArrowRight, Camera, Zap, MessageSquare, Gavel, Share2, 
            PlusCircle, Download, Eye, Sparkles, Droplets, Flame, Landmark, Banknote
        } = lucide;

        // --- COMPONENTES UI COMUNES RM---

        const Icon = ({ name, ...props }) => {
            const LucideIcon = lucide[name];
            return LucideIcon ? <LucideIcon {...props} /> : null;
        };

        const Gauge = ({ value, label }) => {
            const color = value > 90 ? 'text-emerald-500' : value > 70 ? 'text-amber-500' : 'text-red-500';
            return (
                <div className="relative w-32 h-32 flex items-center justify-center">
                    <svg className="w-full h-full transform -rotate-90">
                        <circle cx="50%" cy="50%" r="45%" strokeWidth="8" fill="transparent" className="text-slate-100" stroke="currentColor" />
                        <circle cx="50%" cy="50%" r="45%" strokeWidth="8" fill="transparent" strokeDasharray="251" strokeDashoffset={251 - (251 * value) / 100} className={color} stroke="currentColor" style={{ strokeLinecap: 'round' }} />
                    </svg>
                    <div className="absolute inset-0 flex flex-col items-center justify-center">
                        <span className="text-2xl font-black text-slate-800">{value}%</span>
                        <span className="text-[8px] font-black uppercase text-slate-400">{label}</span>
                    </div>
                </div>
            );
        };

        // --- APP PRINCIPAL ---

        function BlindatoApp() {
            const [profile, setProfile] = useState('admin'); // 'admin', 'tenant', 'owner'
            const [view, setView] = useState('home');
            const [activeWizard, setActiveWizard] = useState(null);

            // Perfil Administrador (Web)
            const AdminView = () => (
                <div className="flex h-screen w-full overflow-hidden animate-in fade-in duration-500">
                    {/* Sidebar */}
                    <aside className="w-72 bg-slate-900 text-white flex flex-col p-6 border-r border-slate-800">
                        <div className="flex items-center gap-3 mb-12 px-2">
                            <div className="w-10 h-10 bg-indigo-500 rounded-xl flex items-center justify-center text-white font-black text-xl">B</div>
                            <div>
                                <h1 className="font-black tracking-tighter text-xl leading-none">BLINDATO</h1>
                                <p className="text-[9px] text-indigo-400 font-black uppercase tracking-widest mt-1">Real Estate OS</p>
                            </div>
                        </div>
                        <nav className="flex-1 space-y-2">
                            {['Dashboard', 'Inquilinos', 'Dueños', 'Propiedades', 'Tesorería', 'Tickets'].map(item => (
