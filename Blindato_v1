                            </div>
                            <Bell size={20} className="text-slate-500" />
                        </div>
                        <p className="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1">Saldo Liquidado para Retiro</p>
                        <h2 className="text-4xl font-black text-white">$760.400</h2>
                        <button className="mt-6 w-full bg-emerald-500 text-slate-900 font-black py-4 rounded-2xl text-[10px] uppercase tracking-widest shadow-lg shadow-emerald-500/20">RETIRAR A MI ALIAS</button>
