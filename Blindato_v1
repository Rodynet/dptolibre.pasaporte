                            <div className="flex items-center gap-3">
                                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Admin" className="w-10 h-10 rounded-full bg-slate-700" alt="Admin" />
                                <div>
                                    <p className="text-xs font-bold">Inmobiliaria Raíces</p>
                                    <p className="text-[9px] text-indigo-400 font-black uppercase">Administrador</p>
