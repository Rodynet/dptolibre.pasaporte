                        <button onClick={() => setProfile('tenant')} className={`px-6 py-2 rounded-full text-[10px] font-black uppercase transition-all ${profile === 'tenant' ? 'bg-indigo-600 text-white shadow-lg' : 'text-slate-400'}`}>Inquilino App</button>
