                                <span className="text-[9px] font-bold text-indigo-500 mb-1">INTERESES MES</span>
                            </div>
                            <p className="text-[9px] text-indigo-600 font-medium mt-2">Tu dinero trabaja mientras Blindato orquesta el pago.</p>
                        </div>
                    </main>
                    
                    <nav className="absolute bottom-0 w-full bg-white px-6 py-5 flex justify-around items-center border-t border-slate-100 shadow-[0_-10px_20px_rgba(0,0,0,0.02)]">
                        <Building2 size={22} className="text-emerald-600" />
