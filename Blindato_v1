                                <div className="bg-white p-6 rounded-[2.5rem] border border-slate-100 shadow-sm flex flex-col items-center">
                                    <Gauge value={94} label="Salud Negocio" />
                                </div>
                                <div className="bg-slate-900 p-6 rounded-[2.5rem] text-white flex flex-col justify-between shadow-xl">
                                    <p className="text-[10px] font-black uppercase opacity-50 tracking-widest">Recaudación Total</p>
                                    <h3 className="text-2xl font-black">$12.540.800</h3>
                                    <div className="flex items-center gap-2 text-emerald-400 text-[10px] font-bold">
                                        <TrendingUp size={14} /> +$12.4k Intereses Hoy
                                    </div>
                                </div>
                                <div className="bg-white p-6 rounded-[2.5rem] border border-slate-100 shadow-sm flex flex-col justify-between">
                                    <p className="text-[10px] font-black uppercase text-slate-400 tracking-widest">Honorarios Listos</p>
                                    <h3 className="text-2xl font-black text-indigo-600">$840.500</h3>
                                    <button className="text-[10px] font-black bg-indigo-50 text-indigo-600 py-2 rounded-xl uppercase">Invertir Saldo</button>
                                </div>
                                <div className="bg-white p-6 rounded-[2.5rem] border border-slate-100 shadow-sm flex flex-col justify-between">
                                    <p className="text-[10px] font-black uppercase text-slate-400 tracking-widest">Liquidaciones</p>
                                    <h3 className="text-2xl font-black">14 Dueños</h3>
                                    <button className="bg-slate-900 text-white py-2 rounded-xl text-[10px] font-black uppercase">Pagar Todo</button>
                                </div>
                            </section>

                            {/* Valla de Atención - El Juez */}
