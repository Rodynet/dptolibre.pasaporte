                                        </div>
                                        <button className="bg-slate-900 text-white px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest group-hover:bg-indigo-600 transition-all shadow-xl shadow-slate-200">DAR OK FINAL</button>
